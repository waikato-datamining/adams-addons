# Charset: UTF-8
# Modules: adams-core,adams-event,adams-json,adams-net,adams-rest,adams-rest-sse,adams-security,adams-webservice-core
#
adams.flow.control.Flow -annotation "Sets up a Server Sent Events (SSE) server that forwards the data from a queue.\\nOpen the following HTML file in your browser to see the events:\\nadams-rest-sse-server_with_queue.html" -execute-on-error adams.flow.control.postflowexecution.Null -execute-on-finish adams.flow.control.postflowexecution.Null -flow-execution-listener adams.flow.execution.NullListener -flow-restart-manager adams.flow.control.flowrestart.NullManager
 adams.flow.standalone.QueueInit
 adams.flow.standalone.RESTServer -web-service "adams.flow.rest.GenericServer -in-interceptor adams.flow.rest.interceptor.incoming.NullGenerator -out-interceptor adams.flow.rest.interceptor.outgoing.NullGenerator -plugin adams.flow.rest.sse.SSEQueueBroadcastResource -feature adams.flow.rest.feature.SSEFeature"
 adams.flow.standalone.SetVariable -name init -var-name count -var-value 0
 adams.flow.source.Start
 adams.flow.control.WhileLoop -condition adams.flow.condition.bool.True
  adams.flow.source.Start
  adams.flow.transformer.IncVariable -var-name count -output-variable-value true
  adams.flow.control.Sleep -interval 2000
  adams.flow.sink.EnQueue