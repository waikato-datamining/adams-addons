adams.flow.control.Flow -annotation "Sets up a Server Sent Events (SSE) server." -execute-on-error adams.flow.control.postflowexecution.Null -execute-on-finish adams.flow.control.postflowexecution.Null -flow-execution-listener adams.flow.execution.NullListener -flow-restart-manager adams.flow.control.flowrestart.NullManager
 adams.flow.standalone.RESTServer -web-service "adams.flow.rest.GenericServer -in-interceptor adams.flow.rest.interceptor.incoming.NullGenerator -out-interceptor adams.flow.rest.interceptor.outgoing.NullGenerator -plugin adams.flow.rest.sse.SSEBroadcastResource -feature adams.flow.rest.feature.SSEFeature"
 adams.flow.source.Start
 adams.flow.control.Sleep -interval 0